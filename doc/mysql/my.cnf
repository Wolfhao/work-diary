[mysqld]
# 内存优化核心配置
innodb_buffer_pool_size = 256M    # 缓存池 256M（MySQL 5.7 核心内存占用）
key_buffer_size = 16M             # 索引缓存
max_connections = 50              # 最大连接数（几人使用足够）
table_open_cache = 64             # 表缓存
sort_buffer_size = 1M             # 排序缓存
read_buffer_size = 1M             # 读缓存
join_buffer_size = 1M             # 连接缓存

# 性能优化
innodb_flush_log_at_trx_commit = 2
sync_binlog = 0
innodb_log_file_size = 64M
innodb_log_buffer_size = 16M

# 字符集
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

[client]
default-character-set = utf8mb4