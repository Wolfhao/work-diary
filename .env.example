# 复制此文件为 .env，填写真实配置（.env 已加入 .gitignore，不会提交到 Git）

# ── 数据库（同机部署的自建 MySQL）─────────────────────────────────────────
# 如果 MySQL 安装在宿主机（即使是通过 Docker 跑的另个容器并映射了 3306 端口）
# 可以使用 host.docker.internal 访问宿主机的 3306
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=work_diary
DB_USER=root
DB_PASS=your_db_password

# ── Redis（同机部署的自建 Redis）─────────────────────────────────────────
# 若用云 Redis，将 REDIS_HOST 改为云 Redis 地址，并删除 docker-compose 中的 redis service
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASS=your_redis_password_here

# ── 微信小程序 ───────────────────────────────────────────────────────────────
WX_APPID=your_wx_appid
WX_SECRET=your_wx_secret

# ── 腾讯云 COS ────────────────────────────────────────────────────────────────
COS_REGION=ap-shanghai
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=your-bucket-name-1234567890
COS_DOMAIN=
