# 复制此文件为 .env，填写真实配置（.env 已加入 .gitignore，不会提交到 Git）

# ── 数据库 ───────────────────────────────────────────────────────────────────
DB_NAME=work_diary
DB_USER=root
DB_PASS=your_strong_password_here

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASS=your_redis_password_here

# ── 微信小程序 ───────────────────────────────────────────────────────────────
WX_APPID=your_wx_appid
WX_SECRET=your_wx_secret

# ── 腾讯云 COS ────────────────────────────────────────────────────────────────
COS_REGION=ap-shanghai
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=your-bucket-name-1234567890
COS_DOMAIN=
