<view class="my-container">

  <!-- 顶部 LOGO + 标语区 -->
  <view class="app-hero">
    <view class="app-logo">📓</view>
    <view class="app-name">年年の工作日记</view>
    <view class="app-slogan">你的接单&结款小助手 ✨</view>
  </view>

  <!-- 功能介绍卡片 -->
  <view class="feature-card">
    <view class="feature-item">
      <text class="feature-emoji">📋</text>
      <view class="feature-text">
        <text class="feature-title">商单管理</text>
        <text class="feature-desc">接单、拍摄、结款，一条龙追踪，拒绝漏单</text>
      </view>
    </view>
    <view class="feature-divider"></view>
    <view class="feature-item">
      <text class="feature-emoji">💰</text>
      <view class="feature-text">
        <text class="feature-title">垫付追踪</text>
        <text class="feature-desc">每一笔垫付都有记录，钱在哪里清清楚楚</text>
      </view>
    </view>
    <view class="feature-divider"></view>
    <view class="feature-item">
      <text class="feature-emoji">📊</text>
      <view class="feature-text">
        <text class="feature-title">数据看板</text>
        <text class="feature-desc">收入、利润、待结款，一屏全掌握</text>
      </view>
    </view>
  </view>

  <!-- 俏皮文案 -->
  <view class="fun-quote">
    <text class="quote-text">"每一单都认真记，每一笔都在心里 🐾"</text>
  </view>

  <!-- 版本号 -->
  <view class="version-row">v1.0.0 · 专为年年打造</view>

  <!-- 退出登录 -->
  <view class="logout-wrap" wx:if="{{hasLoggedIn}}">
    <t-button theme="danger" variant="outline" size="large" block bindtap="onLogout">退出登录</t-button>
  </view>

  <t-toast id="t-toast" />
</view>
